<div class="music-player collapsed" data-music-player>
	<button class="music-orb" type="button" data-music-expand aria-label="展开音乐播放器">
		<span class="music-wave" aria-hidden="true"><i></i><i></i><i></i></span>
		<span class="music-note" aria-hidden="true">♪</span>
	</button>
	<section class="music-panel float-panel" aria-label="背景音乐">
		<div class="music-head">
			<img src="/assets/images/twilight-wallpaper-2.jpg" alt="封面" />
			<div>
				<h2 data-i18n="music.title">深海之息</h2>
				<p data-i18n="music.artist">Youzee Music</p>
				<time data-music-time>0:00 / 0:00</time>
			</div>
			<button class="icon-button mini" type="button" data-music-collapse aria-label="收起">⌄</button>
		</div>
		<div class="music-progress" data-music-progress><span></span></div>
		<div class="music-controls">
			<button type="button" data-music-restart aria-label="重新播放">↺</button>
			<button class="play-button" type="button" data-music-play aria-label="播放">▶</button>
			<a href="/assets/music-shenhai.m4a" download aria-label="下载音乐">⇩</a>
		</div>
		<audio data-music-audio preload="metadata" src="/assets/music-shenhai.m4a"></audio>
	</section>
</div>

<script is:inline src="/site-controls.js"></script>
