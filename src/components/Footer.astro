---
import { GITHUB_URL, SITE_AUTHOR } from '../consts';

const today = new Date();
---

<footer>
	<p>&copy; {today.getFullYear()} {SITE_AUTHOR}. Built with Astro.</p>
	<div class="social-links">
		<a href="/rss.xml">RSS</a>
		<a href={GITHUB_URL} target="_blank">GitHub</a>
	</div>
</footer>
<style>
	footer {
		padding: 2rem 1rem 4rem;
		background: #fff;
		border-top: 1px solid rgb(var(--gray-light));
		color: rgb(var(--gray));
		text-align: center;
	}
	footer p {
		margin: 0;
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 1rem;
		margin-top: 0.75rem;
	}
	.social-links a {
		text-decoration: none;
		color: rgb(var(--gray));
	}
	.social-links a:hover {
		color: rgb(var(--gray-dark));
	}
</style>
