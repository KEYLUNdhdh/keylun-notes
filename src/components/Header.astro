---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header id="navbar" class="site-navbar">
	<nav class="navbar-inner">
		<a class="brand btn-plain" href="/" aria-label="返回首页">
			<span class="brand-icon">⌂</span>
			<span>{SITE_TITLE}</span>
		</a>
		<div class="navbar-links">
			<HeaderLink href="/"><span data-i18n="nav.home">首页</span></HeaderLink>
			<HeaderLink href="/blog"><span data-i18n="nav.archive">归档</span></HeaderLink>
			<HeaderLink href="/projects"><span data-i18n="nav.exhibition">展示</span></HeaderLink>
			<HeaderLink href="/tags"><span data-i18n="nav.tags">标签</span></HeaderLink>
			<HeaderLink href="/about"><span data-i18n="nav.about">关于</span></HeaderLink>
			<a href="/admin/"><span data-i18n="nav.admin">管理</span></a>
		</div>
		<div class="navbar-actions">
			<div class="dropdown">
				<button class="icon-button" type="button" data-panel-toggle="language-panel" aria-label="选择语言">文</button>
				<div class="float-panel menu-panel" id="language-panel" hidden>
					<p class="panel-title" data-i18n="settings.language">选择语言 / Select Language</p>
					<div class="segmented">
						<button type="button" data-lang-choice="zh">中文</button>
						<button type="button" data-lang-choice="en">English</button>
					</div>
				</div>
			</div>
			<div class="dropdown">
				<button class="icon-button" type="button" data-panel-toggle="display-panel" aria-label="显示设置">◐</button>
				<div class="float-panel menu-panel wide" id="display-panel" hidden>
					<label class="setting-row">
						<span data-i18n="settings.color">主题色</span>
						<input type="range" min="0" max="360" value="195" data-hue-control />
					</label>
					<p class="panel-title" data-i18n="settings.theme">主题</p>
					<div class="segmented">
						<button type="button" data-theme-choice="light" data-i18n="settings.light">浅色</button>
						<button type="button" data-theme-choice="dark" data-i18n="settings.dark">深色</button>
						<button type="button" data-theme-choice="system" data-i18n="settings.system">系统</button>
					</div>
					<p class="panel-title" data-i18n="settings.banner">横幅</p>
					<div class="segmented">
						<button type="button" data-wallpaper-choice="banner">Banner</button>
						<button type="button" data-wallpaper-choice="fullscreen">Fullscreen</button>
						<button type="button" data-wallpaper-choice="none">None</button>
					</div>
				</div>
			</div>
		</div>
	</nav>
</header>

<style>
	.site-navbar {
		position: sticky;
		top: 0;
		z-index: 60;
		padding: 0.75rem 1rem;
		pointer-events: none;
	}
	.navbar-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		width: min(var(--page-width), calc(100vw - 2rem));
		height: 4.5rem;
		margin: 0 auto;
		padding: 0 0.75rem;
		border: 1px solid var(--line);
		border-radius: var(--radius-large);
		background: var(--navbar-bg);
		box-shadow: var(--shadow);
		backdrop-filter: blur(24px) saturate(140%);
		pointer-events: auto;
		transition: background 180ms ease, border-color 180ms ease;
	}
	.brand,
	.navbar-links a,
	.icon-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border: 0;
		color: var(--text-90);
		font-weight: 800;
		text-decoration: none;
	}
	.brand {
		gap: 0.5rem;
		height: 3.25rem;
		padding: 0 1rem;
		border-radius: var(--radius);
		white-space: nowrap;
	}
	.brand-icon {
		display: grid;
		place-items: center;
		width: 1.8rem;
		height: 1.8rem;
		border-radius: 0.7rem;
		background: var(--primary);
		color: #fff;
		box-shadow: 0 8px 24px color-mix(in srgb, var(--primary) 45%, transparent);
	}
	.navbar-links {
		display: flex;
		align-items: center;
		gap: 0.15rem;
	}
	.navbar-links a {
		height: 2.8rem;
		padding: 0 0.9rem;
		border-radius: var(--radius-small);
		color: var(--text-75);
		font-size: 0.95rem;
		transition: background 160ms ease, color 160ms ease, transform 160ms ease;
	}
	.navbar-links a:hover,
	.navbar-links a.active {
		background: var(--btn-plain-bg-hover);
		color: var(--text-100);
	}
	.navbar-actions {
		display: flex;
		align-items: center;
		gap: 0.35rem;
	}
	.dropdown {
		position: relative;
	}
	.icon-button {
		width: 2.7rem;
		height: 2.7rem;
		border-radius: var(--radius-small);
		background: transparent;
		cursor: pointer;
	}
	.icon-button:hover {
		background: var(--btn-plain-bg-hover);
	}
	.menu-panel {
		position: absolute;
		top: calc(100% + 0.65rem);
		right: 0;
		width: 17rem;
		padding: 1rem;
	}
	.menu-panel.wide {
		width: 20rem;
	}
	.panel-title {
		margin: 0 0 0.7rem;
		color: var(--text-75);
		font-size: 0.9rem;
		font-weight: 800;
	}
	.setting-row {
		display: grid;
		gap: 0.55rem;
		margin-bottom: 1rem;
		color: var(--text-75);
		font-size: 0.9rem;
		font-weight: 800;
	}
	.segmented {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-bottom: 1rem;
	}
	.segmented:last-child {
		margin-bottom: 0;
	}
	.segmented button {
		min-height: 2.2rem;
		padding: 0 0.8rem;
		border: 0;
		border-radius: var(--radius-small);
		background: var(--btn-regular-bg);
		color: var(--text-75);
		font-weight: 800;
		cursor: pointer;
	}
	.segmented button.active,
	.segmented button:hover {
		background: var(--primary);
		color: #fff;
	}
	input[type='range'] {
		width: 100%;
		accent-color: var(--primary);
	}
	@media (max-width: 880px) {
		.navbar-inner {
			align-items: flex-start;
			flex-wrap: wrap;
			height: auto;
			padding: 0.65rem;
		}
		.navbar-links {
			order: 3;
			width: 100%;
			flex-wrap: wrap;
			overflow: visible;
			padding-bottom: 0.15rem;
		}
		.navbar-links a {
			flex: 1 1 auto;
			min-width: fit-content;
		}
		.menu-panel {
			position: fixed;
			top: 5rem;
			right: 1rem;
			left: 1rem;
			width: auto;
		}
	}
</style>
