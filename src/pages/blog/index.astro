---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { sortPosts } from '../../utils/posts';

const posts = sortPosts(await getCollection('blog'));
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`归档 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<div class="wallpaper fullscreen-wallpaper"></div>
		<div class="wallpaper banner-wallpaper compact"></div>
		<Header />
		<main class="single-column">
			<section class="page-title card-base">
				<p class="eyebrow">Archive</p>
				<h1 data-i18n="page.archive">文章归档</h1>
				<p data-i18n="page.archiveDesc">按时间整理算法、论文、课程和项目笔记。</p>
			</section>
			<section class="post-list">
				{posts.map((post) => (
					<article class="post-card card-base">
						<div class="post-card-main">
							<a class="post-title" href={`/blog/${post.id}/`}>{post.data.title}</a>
							<div class="post-meta">
								<FormattedDate date={post.data.pubDate} />
								<span>/</span>
								<span>{post.data.tags.join(' / ') || 'No Tags'}</span>
							</div>
							<p>{post.data.description}</p>
							<div class="post-stats">
								<span>{post.body?.length ?? 0} <span data-i18n="post.words">字</span></span>
								<span>|</span>
								<span>{Math.max(1, Math.ceil((post.body?.length ?? 0) / 500))} <span data-i18n="post.minute">分钟</span></span>
							</div>
						</div>
						<a class="post-cover" href={`/blog/${post.id}/`} aria-label={post.data.title}>
							<span>{post.data.tags.slice(0, 3).join(' / ') || 'No Tags'}</span>
						</a>
					</article>
				))}
			</section>
		</main>
		<Footer />
	</body>
</html>
