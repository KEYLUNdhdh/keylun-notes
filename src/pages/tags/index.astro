---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { getTagCounts, tagToSlug } from '../../utils/posts';

const tags = getTagCounts(await getCollection('blog'));
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`标签 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<div class="wallpaper fullscreen-wallpaper"></div>
		<div class="wallpaper banner-wallpaper compact"></div>
		<Header />
		<main class="single-column">
			<section class="page-title card-base">
				<p class="eyebrow">Tags</p>
				<h1 data-i18n="page.tags">标签</h1>
				<p data-i18n="page.tagsDesc">按主题快速找到算法、论文、项目和站点记录。</p>
			</section>
			<section class="card-base tag-page-cloud">
				{tags.map(([tag, count]) => <a href={`/tags/${tagToSlug(tag)}/`}><span>{tag}</span><strong>{count}</strong></a>)}
			</section>
		</main>
		<Footer />
	</body>
</html>
