---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import profile from '../data/profile.json';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`关于 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<div class="site-bg"></div>
		<Header />
		<main>
			<section class="about-hero glass-panel">
				<img src={profile.avatar} alt="博客头像" width="150" height="150" />
				<div>
					<p class="eyebrow">关于我</p>
					<h1>{profile.name}</h1>
					<p class="multiline">{profile.aboutIntro}</p>
					<div class="profile-links">
						{profile.links.map((link) => <a href={link.url} target="_blank" rel="noreferrer">{link.label}</a>)}
					</div>
				</div>
			</section>

			<section class="content-block glass-panel">
				<h2>当前关注</h2>
				<ul class="focus-list">
					{profile.focus.map((item) => <li>{item}</li>)}
				</ul>
			</section>

			<section class="content-block glass-panel">
				<h2>教育经历</h2>
				<div class="education-list large">
					{
						profile.education.map((item) => (
							<article>
								<div class="edu-mark">{item.mark}</div>
								<div>
									<h3>{item.school}</h3>
									<p>{item.program}</p>
									<time>{item.time}</time>
									<p class="multiline">{item.detail}</p>
								</div>
							</article>
						))
					}
				</div>
			</section>

			<section class="content-block glass-panel">
				<h2>联系方式</h2>
				<p class="multiline">{profile.contact}</p>
			</section>
		</main>
		<Footer />
	</body>
</html>
