---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import profile from '../data/profile.json';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getTagCounts, sortPosts, tagToSlug } from '../utils/posts';

const posts = sortPosts(await getCollection('blog'));
const latestPosts = posts.slice(0, 5);
const tags = getTagCounts(posts);
const categories = [
	['算法笔记', posts.filter((post) => post.data.tags.includes('algorithm')).length],
	['论文阅读', posts.filter((post) => post.data.tags.includes('paper-reading')).length],
	['项目复盘', posts.filter((post) => post.data.tags.includes('project')).length],
	['站点记录', posts.filter((post) => post.data.tags.includes('meta')).length],
].filter(([, count]) => Number(count) > 0);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<div class="site-bg"></div>
		<Header />
		<section class="twilight-banner">
			<div class="banner-shade"></div>
			<div class="banner-content">
				<p class="eyebrow">Keylun 的个人博客</p>
				<h1>{profile.heroTitle}</h1>
				<p class="intro multiline">{profile.heroDescription}</p>
				<div class="actions">
					<a class="button primary" href="/blog">阅读文章</a>
					<a class="button" href="/about">关于我</a>
				</div>
			</div>
		</section>

		<main class="home-shell">
			<div class="home-grid">
				<section class="feed">
					<div class="section-title">
						<div>
							<p class="eyebrow">最近更新</p>
							<h2>最新文章</h2>
						</div>
						<a href="/blog">全部文章</a>
					</div>
					<div class="article-list">
						{
							latestPosts.map((post) => (
								<a class="article-row" href={`/blog/${post.id}/`}>
									<div class="article-main">
										<p class="date">
											<FormattedDate date={post.data.pubDate} />
										</p>
										<h3>{post.data.title}</h3>
										<p>{post.data.description}</p>
										<div class="tags">
											{post.data.tags.map((tag) => (
												<span>{tag}</span>
											))}
										</div>
									</div>
								</a>
							))
						}
					</div>
				</section>

				<aside class="profile-sidebar" aria-label="个人信息">
					<section class="side-card identity-card">
						<a href="/about" aria-label="查看关于我">
							<img src={profile.avatar} alt="博客头像" width="160" height="160" />
						</a>
						<h2>{profile.name}</h2>
						<div class="accent-line"></div>
						<p class="multiline">{profile.tagline}</p>
						<div class="profile-links compact">
							{profile.links.map((link) => <a href={link.url} target="_blank" rel="noreferrer">{link.label}</a>)}
						</div>
					</section>

					<section class="side-card">
						<div class="side-title">
							<h2>分类</h2>
							<a href="/blog">更多</a>
						</div>
						<div class="category-list">
							{
								categories.map(([name, count]) => (
									<div>
										<span>{name}</span>
										<strong>{count}</strong>
									</div>
								))
							}
						</div>
					</section>

					<section class="side-card">
						<div class="side-title">
							<h2>标签</h2>
							<a href="/tags">全部</a>
						</div>
						<div class="tag-cloud compact">
							{
								tags.map(([tag, count]) => (
									<a href={`/tags/${tagToSlug(tag)}/`}>
										<span>{tag}</span>
										<strong>{count}</strong>
									</a>
								))
							}
						</div>
					</section>

					<section class="side-card">
						<h2>教育经历</h2>
						<div class="education-list">
							{
								profile.education.map((item) => (
									<article>
										<div class="edu-mark">{item.mark}</div>
										<div>
											<h3>{item.school}</h3>
											<p>{item.program}</p>
											<time>{item.time}</time>
										</div>
									</article>
								))
							}
						</div>
					</section>
				</aside>
			</div>
		</main>
		<Footer />
	</body>
</html>
