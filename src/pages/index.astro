---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import profile from '../data/profile.json';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getTagCounts, sortPosts, tagToSlug } from '../utils/posts';

const posts = sortPosts(await getCollection('blog'));
const tags = getTagCounts(posts);
const categories = [
	['Algorithm Notes', posts.filter((post) => post.data.tags.includes('algorithm')).length],
	['Paper Reading', posts.filter((post) => post.data.tags.includes('paper-reading')).length],
	['Projects', posts.filter((post) => post.data.tags.includes('project')).length],
	['Meta', posts.filter((post) => post.data.tags.includes('meta')).length],
].filter(([, count]) => Number(count) > 0);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="home-shell">
			<section class="profile-hero">
				<div class="hero-copy">
					<p class="eyebrow">Personal technical blog</p>
					<h1>{profile.heroTitle}</h1>
					<p class="intro">{profile.heroDescription}</p>
					<div class="actions">
						<a class="button primary" href="/blog">阅读文章</a>
						<a class="button" href="/tags">按标签浏览</a>
					</div>
				</div>
				<img class="hero-avatar" src={profile.avatar} alt="博客头像" width="220" height="220" />
			</section>

			<div class="home-grid">
				<section class="feed">
					<div class="section-title">
						<h2>最新文章</h2>
						<a href="/blog">全部文章</a>
					</div>
					<div class="article-list">
						{
							posts.map((post) => (
								<a class="article-row" href={`/blog/${post.id}/`}>
									<div>
										<p class="date">
											<FormattedDate date={post.data.pubDate} />
										</p>
										<h2>{post.data.title}</h2>
										<p>{post.data.description}</p>
										<div class="tags">
											{post.data.tags.map((tag) => (
												<span>{tag}</span>
											))}
										</div>
									</div>
								</a>
							))
						}
					</div>
				</section>

				<aside class="profile-sidebar" aria-label="个人信息">
					<section class="side-card identity-card">
						<img src={profile.avatar} alt="博客头像" width="132" height="132" />
						<h2>{profile.name}</h2>
						<p>{profile.tagline}</p>
					</section>

					<section class="side-card">
						<div class="side-title">
							<h2>分类</h2>
							<a href="/blog">更多</a>
						</div>
						<div class="category-list">
							{
								categories.map(([name, count]) => (
									<div>
										<span>{name}</span>
										<strong>{count}</strong>
									</div>
								))
							}
						</div>
					</section>

					<section class="side-card">
						<div class="side-title">
							<h2>标签</h2>
							<a href="/tags">全部</a>
						</div>
						<div class="tag-cloud compact">
							{
								tags.map(([tag, count]) => (
									<a href={`/tags/${tagToSlug(tag)}/`}>
										<span>{tag}</span>
										<strong>{count}</strong>
									</a>
								))
							}
						</div>
					</section>

					<section class="side-card">
						<h2>教育经历</h2>
						<div class="education-list">
							{
								profile.education.map((item) => (
									<article>
										<div class="edu-mark">{item.mark}</div>
										<div>
											<h3>{item.school}</h3>
											<p>{item.program}</p>
											<time>{item.time}</time>
											<p>{item.detail}</p>
										</div>
									</article>
								))
							}
						</div>
					</section>
				</aside>
			</div>
		</main>
		<Footer />
	</body>
</html>
