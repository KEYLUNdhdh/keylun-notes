---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { tagToSlug } from '../utils/posts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, tags, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<div class="wallpaper fullscreen-wallpaper"></div>
		<div class="wallpaper banner-wallpaper compact"></div>
		<Header />
		<main class="post-shell">
			<article class="post-article card-base">
				{heroImage && <div class="hero-image"><Image width={1020} height={510} src={heroImage} alt="" /></div>}
				<header class="post-page-title">
					<div class="post-meta">
						<FormattedDate date={pubDate} />
						{updatedDate && <><span>/</span><span data-i18n="post.updated">最后更新于</span><FormattedDate date={updatedDate} /></>}
					</div>
					<h1>{title}</h1>
					<p>{description}</p>
					<div class="tags">
						{tags.map((tag) => <a href={`/tags/${tagToSlug(tag)}/`}>{tag}</a>)}
					</div>
				</header>
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
